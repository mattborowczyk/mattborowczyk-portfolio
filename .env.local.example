# Sanity — get these from https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token (read-write) — needed for draft previews and mutations
# Create at: https://sanity.io/manage → API → Tokens
SANITY_API_TOKEN=your_sanity_api_token

# MailerLite — get from https://app.mailerlite.com/integrations/api
MAILERLITE_API_KEY=your_mailerlite_api_key
# The ID of the group/segment subscribers are added to (optional)
MAILERLITE_GROUP_ID=your_group_id
